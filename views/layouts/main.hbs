<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Configurator</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f0f2f5; color: #1a1a2e; height: 100vh; display: flex; flex-direction: column; }
    header {
      background: #1a1a2e;
      color: #fff;
      padding: 0 24px;
      height: 52px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    header .icon { font-size: 1.2rem; }
    header h1   { font-size: .95rem; font-weight: 700; letter-spacing: .04em; }
    header span { color: #64748b; font-size: .8rem; margin-left: auto; }
    .layout {
      display: flex;
      flex: 1;
      overflow: hidden;
      gap: 0;
    }
    .panel-left {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      border-right: 1px solid #e2e8f0;
    }
    .panel-left .panel-head {
      background: #fff;
      padding: 14px 20px;
      border-bottom: 1px solid #e2e8f0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .panel-left .panel-head h2 { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #475569; }
    .badge { background: #e0f2fe; color: #0369a1; border-radius: 20px; padding: 2px 10px; font-size: .75rem; font-weight: 700; }
    .combos-list {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .combo-card {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      font-size: .85rem;
      transition: box-shadow .15s;
    }
    .combo-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,.08); border-color: #cbd5e1; }
    .tag {
      display: flex;
      align-items: center;
      gap: 0;
      border-radius: 5px;
      overflow: hidden;
      font-size: .78rem;
      font-weight: 500;
    }
    .tag-param { background: #1e293b; color: #94a3b8; padding: 3px 7px; font-size: .7rem; text-transform: uppercase; letter-spacing: .05em; }
    .tag-value { background: #f1f5f9; color: #1e293b; padding: 3px 9px; border: 1px solid #e2e8f0; border-left: none; border-radius: 0 5px 5px 0; }
    .combo-sep { color: #cbd5e1; font-size: .8rem; }
    .empty-state { text-align: center; padding: 60px 20px; color: #94a3b8; font-size: .9rem; }
    .panel-right {
      width: 360px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: #fff;
    }
    .panel-right .panel-head {
      padding: 14px 20px;
      border-bottom: 1px solid #e2e8f0;
      flex-shrink: 0;
    }
    .panel-right .panel-head h2 { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #475569; margin-bottom: 12px; }
    .add-form { display: flex; flex-direction: column; gap: 8px; }
    .add-form input {
      width: 100%;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      padding: 8px 10px;
      font-size: .82rem;
      color: #1a1a2e;
    }
    .add-form input:focus { outline: none; border-color: #3b82f6; }
    .add-form input::placeholder { color: #94a3b8; }
    .add-form button {
      background: #1a1a2e;
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 8px;
      font-size: .82rem;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
    }
    .add-form button:hover { background: #2d2d4e; }
    .hint { font-size: .72rem; color: #94a3b8; margin-top: 2px; }
    .params-list {
      flex: 1;
      overflow-y: auto;
      padding: 12px 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .param-card {
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      overflow: hidden;
    }
    .param-card-head {
      background: #f8fafc;
      padding: 8px 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid #e2e8f0;
    }
    .param-name { font-weight: 700; font-size: .85rem; color: #1e293b; }
    .param-count { font-size: .72rem; color: #94a3b8; }
    .param-card-body { padding: 10px 12px; }
    .choices-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px; }
    .choice-chip {
      background: #f1f5f9;
      border: 1px solid #e2e8f0;
      color: #334155;
      border-radius: 20px;
      padding: 2px 10px;
      font-size: .75rem;
      font-weight: 500;
    }
    .param-actions { display: flex; gap: 6px; }
    .btn-edit {
      flex: 1;
      background: none;
      border: 1px solid #e2e8f0;
      border-radius: 5px;
      padding: 5px 0;
      font-size: .75rem;
      color: #475569;
      cursor: pointer;
    }
    .btn-edit:hover { border-color: #94a3b8; }
    .btn-del {
      background: none;
      border: 1px solid #fecaca;
      border-radius: 5px;
      padding: 5px 10px;
      font-size: .75rem;
      color: #ef4444;
      cursor: pointer;
    }
    .btn-del:hover { background: #fef2f2; }
    .inline-edit { display: none; padding: 10px 12px; border-top: 1px solid #e2e8f0; background: #f8fafc; }
    .inline-edit.open { display: block; }
    .inline-edit input { width: 100%; border: 1px solid #e2e8f0; border-radius: 5px; padding: 6px 8px; font-size: .8rem; margin-bottom: 6px; }
    .inline-edit input:focus { outline: none; border-color: #3b82f6; }
    .edit-btns { display: flex; gap: 6px; }
    .btn-save   { flex: 1; background: #22c55e; color: #fff; border: none; border-radius: 5px; padding: 6px; font-size: .78rem; font-weight: 600; cursor: pointer; }
    .btn-cancel { background: none; border: 1px solid #e2e8f0; border-radius: 5px; padding: 6px 10px; font-size: .78rem; color: #64748b; cursor: pointer; }

    .error { background: #fee2e2; color: #b91c1c; padding: 10px 14px; margin: 12px; border-radius: 6px; font-size: .8rem; }
  </style>
</head>
<body>
  <header>
    <h1>Configurator</h1>
  </header>
  <div class="layout">
    {{{body}}}
  </div>

  <script>
    function openEdit(id, param, choices) {
      document.querySelectorAll('.inline-edit').forEach(el => el.classList.remove('open'));
      const el = document.getElementById('edit-' + id);
      el.classList.add('open');
      el.querySelector('[name=parameter]').value = param;
      el.querySelector('[name=choices]').value   = choices;
    }
    function closeEdit(id) {
      document.getElementById('edit-' + id).classList.remove('open');
    }
  </script>
</body>
</html>